{
  "name": "bastion",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source security gateway for AI agent traffic",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint packages/*/src --ext .ts",
    "typecheck": "pnpm -r run typecheck",
    "dev": "pnpm -r --parallel run dev",
    "clean": "find . -name dist -type d | xargs rm -rf"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
