{
  "name": "@openbastion-ai/proxy",
  "version": "0.2.5",
  "description": "Core proxy server for Bastion",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@openbastion-ai/config": "workspace:*",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
